<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs') %>

<div class="container py-4">

    <!-- Success Toast -->
    <% if (success) { %>
    <div class="toast-container">
        <div class="toast show align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-semibold">
                    <i class="bi bi-check-circle me-2"></i><%= success %>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
    <script>setTimeout(() => { document.querySelector('.toast')?.remove(); }, 3000);</script>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-list-ul me-2"></i>Supermarket Admin</h2>
        <a href="/bike/add" class="btn btn-warning fw-bold">
            <i class="bi bi-plus-circle me-1"></i>Add New Product
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <% if (bikes.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Brand</th>
                            <th>Model</th>
                            <th>CC</th>
                            <th>Price (฿)</th>
                            <th>Stock</th>
                            <th>Slug</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bikes.forEach(bike => { %>
                        <tr>
                            <td><%= bike.id %></td>
                            <td style="position:relative;">
                                <img src="/assets/img/<%= bike.image %>"
                                     class="bike-img"
                                     alt="<%= bike.model %>"
                                     onerror="this.src='https://placehold.co/80x60?text=No+Image'">
                                <% if (bike.stock === 0) { %>
                                    <span class="badge bg-danger"
                                          style="position:absolute;top:8px;left:8px;font-size:0.65rem;">
                                        Out of Stock
                                    </span>
                                <% } %>
                            </td>
                            <td><span class="badge bg-primary"><%= bike.brand %></span></td>
                            <td class="fw-semibold"><%= bike.model %></td>
                            <td><%= bike.cc %> cc</td>
                            <td class="text-success fw-bold">฿<%= parseFloat(bike.price).toLocaleString() %></td>
                            <td>
                                <% if (bike.stock === 0) { %>
                                    <span class="text-danger fw-bold">0 — หมดแล้ว!</span>
                                <% } else if (bike.stock <= 3) { %>
                                    <span class="text-warning fw-bold"><%= bike.stock %> — ใกล้หมด</span>
                                <% } else { %>
                                    <span class="text-success fw-semibold"><%= bike.stock %></span>
                                <% } %>
                            </td>
                            <td><code><%= bike.slug %></code></td>
                            <td>
                                <a href="/bike/edit/<%= bike.id %>" class="btn btn-sm btn-warning me-1">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <button class="btn btn-sm btn-danger"
                                    onclick="confirmDelete(<%= bike.id %>, '<%= bike.brand %> <%= bike.model %>')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="text-center py-5">
                <i class="bi bi-bicycle" style="font-size:4rem; color:#bbb;"></i>
                <p class="mt-3 text-muted">No bikes found.</p>
                <a href="/bike/add" class="btn btn-warning">Add First Bike</a>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>คุณแน่ใจหรือไม่ว่าต้องการลบรายการนี้?</p>
                <p class="fw-bold fs-5" id="deleteBikeName"></p>
                <p class="text-muted small">การลบนี้ไม่สามารถย้อนกลับได้</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>ยกเลิก
                </button>
                <a id="deleteConfirmBtn" href="#" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>ยืนยัน ลบ
                </a>
            </div>
        </div>
    </div>
</div>

<script>
function confirmDelete(id, name) {
    document.getElementById('deleteBikeName').textContent = name;
    document.getElementById('deleteConfirmBtn').href = '/bike/delete/' + id;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>

<%- include('partials/footer.ejs') %>
